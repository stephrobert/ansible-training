#cloud-config
# Cloud-init minimal du control node Ansible.
# Inspiration : ancien lab `ansible-training` — cloud-init ne fait que
# poser un user `ansible` avec sa clé SSH, le reste est installé par Ansible
# lui-même (cf. labs/000-prepare-managed-nodes/playbook.yml puis bootstrap
# Ansible côté pédagogique). Cela accélère make provision (pas de dnf install
# ni de reboot programmé) et matérialise concrètement le principe "Ansible
# se prépare lui-même".
#
# Variables substituées par provision.sh : __HOSTNAME__, __SSH_PUBKEY__

hostname: __HOSTNAME__
fqdn: __HOSTNAME__.lab
manage_etc_hosts: true
preserve_hostname: false

users:
  - name: ansible
    groups: [wheel]
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    shell: /bin/bash
    lock_passwd: true
    ssh_authorized_keys:
      - __SSH_PUBKEY__

disable_root: true
ssh_pwauth: false
