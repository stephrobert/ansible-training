LAB_ROOT := $(shell git rev-parse --show-toplevel 2>/dev/null || (cd ../.. && pwd))

.PHONY: help clean

help:    ## Affiche cette aide
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "  %-10s %s\n", $$1, $$2}'

clean:   ## Supprime sortie inspect locale
	@rm -rf $(LAB_ROOT)/labs/ee/inspection/inspect-output/ 2>/dev/null || true
	@echo "Sortie inspect du lab 85 nettoyée."
