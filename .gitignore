# Collections installées par ansible-galaxy pendant le lab collections/requirements.
# 36 Mo de dépendances téléchargées : un `git add -A` les suit, et le hook
# check-solutions-encrypted.sh refuse alors le commit en se plaignant du
# chiffrement, message qui n'a rien à voir avec la cause.
solution/collections/local_collections/
labs/collections/requirements/local_collections/

# Clé privée OpenPGP du lab Passbolt (exportée par l'apprenant) — jamais commit
labs/**/.passbolt-private.asc

# Dépôt Git local du lab ansible-pull (créé par l'apprenant)
labs/pratiques/ansible-pull-gitops/repo-pull/

# Artefacts générés par les challenges (ne jamais commit)
#
# Fichiers vault que le challenge demande a l'apprenant de CREER. Les
# livrer chiffres ne protege rien : le mot de passe qui les ouvre est
# celui que setup-lab-vault-passwords.sh distribue a tout le monde, donc
# un `ansible-vault view` suffit a lire la reponse attendue.
labs/vault/dans-roles/roles/secured_app/vars/main.yml
labs/vault/playbooks-mixtes/inventory/group_vars/all/vault.yml
labs/vault/playbooks-mixtes/inventory/group_vars/webservers/vault.yml
labs/**/challenge/vault-secret.yml
labs/**/challenge/.vault-pass
labs/**/challenge/.vault_password
labs/**/.vault_password
# Les vault-id nommes suffixent le fichier (.vault_password_dev, _prod...).
# Sans ce glob, la regle ci-dessus les rate et le secret part dans l index.
labs/**/.vault_password_*
labs/**/challenge/.vault_password_*
labs/**/challenge/files/*.pub.key.pub

# Clés SSH générées par les labs (PRIVÉES) — ne jamais commit.
# Naming trompeur hérité du lab authorized-key : `alice.pub.key` est la clé
# PRIVÉE (perms 600), `alice.pub.key.pub` est la clé PUBLIQUE (perms 644).
# Le README du lab doit expliquer comment regénérer la paire :
#   ssh-keygen -t ed25519 -f alice.pub.key -N "" -C alice@laptop
labs/**/files/*.pub.key
labs/**/files/*.pub.key.pub

# Sortie des fetch (lab 34) — artefacts de tests
collected/*
!collected/.gitkeep

# Mot de passe Vault du formateur — ne JAMAIS committer
# Sert à chiffrer/déchiffrer les solutions de référence dans solution/
# Sauvegarder le password ailleurs (gestionnaire de mots de passe, repo privé)
.vault-pass
.vault-pass.txt

# ── CLI dsoxlab : état runtime local (par dépôt) ──
# Contexte de session posé par `dsoxlab use` et base de progression locale.
# Ne jamais versionner : c'est l'avancement d'un apprenant, pas du contenu.
.dsoxlab-context.json
.dsoxlab.db

# Bases de progression héritées (dsoxlab < 0.1.x, stockage XDG désormais :
# ~/.local/share/dsoxlab/progress.db, hors dépôt. Override via DSOXLAB_DB).
.progress.db
progress.db

# Workdirs apprenant : générés par `dsoxlab run` depuis fixtures/, ils
# contiennent le travail en cours. Le fixture est versionné, le workdir non.
labs/**/challenge/work/

# Clé SSH privée du lab : JAMAIS commitée.
# Régénérée par `dsoxlab instructor bootstrap`.
ssh/id_ed25519
ssh/id_rsa
ssh/*_key

