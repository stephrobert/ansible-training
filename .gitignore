# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Abstra
# Abstra is an AI-powered process automation framework.
# Ignore directories containing user credentials, local state, and settings.
# Learn more at https://abstra.io/docs
.abstra/

# Visual Studio Code
#  Visual Studio Code specific template is maintained in a separate VisualStudioCode.gitignore
#  that can be found at https://github.com/github/gitignore/blob/main/Global/VisualStudioCode.gitignore
#  and can be added to the global gitignore or merged into this file. However, if you prefer,
#  you could uncomment the following to ignore the enitre vscode folder
# .vscode/

# Ruff stuff:
.ruff_cache/

# PyPI configuration file
.pypirc

# Cursor
#  Cursor is an AI-powered code editor. `.cursorignore` specifies files/directories to
#  exclude from AI features like autocomplete and code analysis. Recommended for sensitive data
#  refer to https://docs.cursor.com/context/ignore-files
.cursorignore
.cursorindexingignore
.ansible/.lock
.test.md
# Note: solution/ est versionné mais TOUS ses .yml/.sh/.j2/.txt sont
# chiffrés via ansible-vault (cf. .vault-pass + cibles `make solutions-lock`).
# Ne jamais commiter en clair.
.github/copilot-instructions.md
# === Lab KVM/libvirt + Ansible ===
# Cache et artefacts Ansible
.ansible_facts/
.ansible/
*.retry

# Logs et tempos labs
labs/**/expected-output.tmp
labs/**/*.log

# Clé SSH du lab (regénérée par bootstrap)
ssh/id_ed25519
ssh/id_ed25519.pub

# Cloud-init ISOs et fichiers générés par provision.sh
# (les .tmpl sources restent versionnés)
infra/virt-install/cloud-init/control-node/
infra/virt-install/cloud-init/web1/
infra/virt-install/cloud-init/web2/
infra/virt-install/cloud-init/db1/

# Logs provision
infra/virt-install/logs/

# Build/lint cache
.ansible-lint-cache/

# Solutions des challenges écrites par l'apprenant — ne jamais committer
# (la solution officielle du formateur vit dans solution/, chiffrée via vault)
labs/**/challenge/solution.yml
labs/**/challenge/solution.sh
labs/**/challenge/solution.py

# Artefacts générés par les challenges (ne jamais commit)
labs/**/challenge/vault-secret.yml
labs/**/challenge/.vault-pass
labs/**/challenge/.vault_password
labs/**/.vault_password
labs/**/challenge/files/*.pub.key.pub

# Clés SSH générées par les labs (PRIVÉES) — ne jamais commit.
# Naming trompeur hérité du lab authorized-key : `alice.pub.key` est la clé
# PRIVÉE (perms 600), `alice.pub.key.pub` est la clé PUBLIQUE (perms 644).
# Le README du lab doit expliquer comment regénérer la paire :
#   ssh-keygen -t ed25519 -f alice.pub.key -N "" -C alice@laptop
labs/**/files/*.pub.key
labs/**/files/*.pub.key.pub

# Sortie des fetch (lab 34) — artefacts de tests
collected/*
!collected/.gitkeep

# Mot de passe Vault du formateur — ne JAMAIS committer
# Sert à chiffrer/déchiffrer les solutions de référence dans solution/
# Sauvegarder le password ailleurs (gestionnaire de mots de passe, repo privé)
.vault-pass
.vault-pass.txt

# CLI dsoxlab : la SQLite est locale à chaque apprenant
# Stockée par défaut dans ~/.local/share/dsoxlab/progress.db (hors repo).
# Override via env DSOXLAB_DB.
.progress.db
progress.db
